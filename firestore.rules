
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roleAdmin/$(request.auth.uid)) || 
        request.auth.token.email == "admin@epao.com"
      );
    }

    function isLawyer() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid));
    }

    // Public Case Navigator Data
    match /caseRequirements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Appointments - Public for creation and reference lookup to support Guest Portal
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }

    // Official Case Records
    match /cases/{caseId} {
      allow get: if isAdmin() || (isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.lawyerId == request.auth.uid));
      allow list: if isAdmin() || isLawyer() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)));
      allow create, update, delete: if isAdmin();
    }

    // Users and Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isLawyer();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      
      match /profile/{profileId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Role-based Access Control Registry
    match /roleAdmin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /roleLawyer/{userId} {
      // Allow everyone to see lawyer profiles (names and photos)
      allow get: if isSignedIn();
      allow list: if true;
      allow write: if isAdmin();
    }

    match /lawyersEmail/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lawyerAvailability/{availId} {
      allow read: if true;
      allow write: if isLawyer() || isAdmin();
    }
  }
}
