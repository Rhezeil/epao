rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isLawyer() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isLawyer();
      allow list: if isAdmin() || isLawyer();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Lawyer Availability rules.
       */
      match /availability/{availabilityId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for official Legal Cases.
     */
    match /cases/{caseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow listing for dashboard workstation
      allow create: if isAdmin();
      allow update: if isLawyer() || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for Appointments.
     */
    match /appointments/{apptId} {
      allow get: if isSignedIn() || (request.query.filters.referenceCode != null);
      allow list: if isSignedIn() || (request.query.filters.dateString != null) || (request.query.filters.referenceCode != null);
      allow create: if true; // Allow public booking
      allow update: if isSignedIn() || (request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    /**
     * @description Role Marker Collections.
     */
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow bootstrap admin to create their doc, otherwise require admin privileges for writes
      allow create: if isOwner(adminId) && request.auth.token.email == "admin@epao.com";
      allow update, delete: if isAdmin();
    }

    match /roleLawyer/{lawyerId} {
      allow get, list: if isSignedIn();
      // Allow creation by the user themselves (bootstrap) or by an existing admin
      allow create: if isOwner(lawyerId) || isAdmin();
      allow update: if isOwner(lawyerId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /lawyersEmail/{email} {
      allow get: if true;
    }
  }
}