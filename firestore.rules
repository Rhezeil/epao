rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Updated to match the requested 'admins' collection path
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isLawyer() {
      return exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid));
    }

    function isClient() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // ===== APPOINTMENTS =====

    match /appointments/{apptId} {
      // Admin: Full oversight
      allow read, write, delete: if isAdmin();

      // Role-Based List/Get (Strictly matching query filters)
      allow read: if (isSignedIn() &&
           (resource.data.lawyerId == request.auth.uid
            || resource.data.clientId == request.auth.uid));

      // Public: Allowed to lookup by code (Supported by code logic)
      allow list: if resource.data.referenceCode != null;
      allow get: if resource.data.referenceCode != null;

      // CREATE appointment (booking allowed)
      allow create: if true;

      // UPDATE (lawyer or client)
      allow update: if (isSignedIn() &&
           (resource.data.lawyerId == request.auth.uid
            || resource.data.clientId == request.auth.uid));
    }

    // ===== CASES =====

    match /cases/{caseId} {
      allow list: if isAdmin() || (isSignedIn() && (resource.data.lawyerId == request.auth.uid || resource.data.clientId == request.auth.uid));
      allow get: if isAdmin() || (isSignedIn() && (resource.data.lawyerId == request.auth.uid || resource.data.clientId == request.auth.uid));
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ===== USER REGISTRY =====

    match /users/{userId} {
      allow get: if isAdmin() || isLawyer() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /profile/{profileId} {
        allow read, write: if isAdmin() || isLawyer() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /admins/{adminId} {
      allow read, write: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
    }

    match /roleLawyer/{lawyerId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == lawyerId);
    }

    // ===== REFERENCE DATA =====

    match /caseRequirements/{reqId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /lawyersEmail/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}