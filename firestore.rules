
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleAdmin/$(request.auth.uid));
    }

    function isLawyer() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid));
    }

    match /caseRequirements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isLawyer();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    match /cases/{caseId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid) || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      allow list: if isAdmin() || isLawyer() || isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow get, list, create, update: if true;
    }

    match /lawyerAvailability/{availId} {
      allow read: if true;
      allow write: if isLawyer() || isAdmin();
    }

    match /roleAdmin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // Allow bootstrap admin to create their own record
      allow write: if isOwner(userId) && (request.auth.token.email == "admin@epao.com" || isAdmin());
    }
    
    match /roleLawyer/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if true;
      // Allow authorized lawyers to create their own record
      allow write: if isOwner(userId) && (request.auth.token.email.matches('.*@lawyers\\.com') || isAdmin());
    }

    match /lawyersEmail/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roleAdmin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Version: 2024-05-24T15:30:00Z - Bootstrap-Ready RBAC
  }
}
