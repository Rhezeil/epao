
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LexConnect Security Architecture
     * Centralized synchronization for a multi-portal legal system.
     * Roles: Admin (Full), Lawyer (Assigned), Client (Self), Guest (Public).
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Hardened Admin check. Prioritizes bootstrap email for immediate access.
     */
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "admin@epao.com") ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isLawyer() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower().endsWith('@lawyers.com')) ||
        exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /** @description System-wide administrative records. */
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == "admin@epao.com");
    }

    /** @description Professional Lawyer profiles and their professional availability. */
    match /roleLawyer/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /availability/{dateId} {
        allow read: if true; // Publicly readable for scheduling
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    /** @description Citizen profiles and identity metadata. */
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || isLawyer());
      allow write: if isOwner(userId) || isAdmin();

      match /profile/{profileId} {
        allow read: if isOwner(userId) || isAdmin() || isLawyer();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    /** @description Statutory database for legal requirements and roadmaps. */
    match /caseRequirements/{caseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** @description Global appointment registry.
     * Explicitly allows read (list/get) for synchronization across all portals.
     * Creation and updates are allowed for system-wide booking flows.
     */
    match /appointments/{appointmentId} {
      allow read: if true; 
      allow create: if true; 
      allow update: if true; 
      allow delete: if isAdmin();
    }

    /** @description Official legal case records handled by public attorneys. */
    match /cases/{caseId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.lawyerId == request.auth.uid || resource.data.clientId == request.auth.uid));
      allow list: if isAdmin() || isSignedIn();
      allow create: if isAdmin() || isLawyer();
      allow update: if isAdmin() || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      allow delete: if isAdmin();

      match /documents/{docId} {
        allow read, write: if isAdmin() || (isSignedIn() && (get(/databases/$(database)/documents/cases/$(caseId)).data.lawyerId == request.auth.uid || get(/databases/$(database)/documents/cases/$(caseId)).data.clientId == request.auth.uid));
      }
    }

    /** @description Authorized lawyer email whitelist. */
    match /lawyersEmail/{email} {
      allow read: if true;
    }
  }
}
