
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleAdmin/$(request.auth.uid));
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
    }

    match /cases/{caseId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid) || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      allow list: if isAdmin() || isSignedIn(); // Restricted by query filters in app
      allow create, update: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow get: if true; // Public for reference code lookup
      allow create: if true; // Guests can book
      allow update: if true; // Guests can cancel/reschedule via reference code check in logic
      allow list: if isAdmin() || isSignedIn();
    }

    match /roleAdmin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /roleLawyer/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || isSignedIn();
      allow write: if isAdmin();
    }
  }
}
