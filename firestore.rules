rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset balances public access for the legal navigator and guest bookings
     * with strict administrative and professional oversight for case management.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is a registered Admin. */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@epao.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    /** @description Checks if the user is an authorized Lawyer. */
    function isLawyer() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid));
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Administrative roles. Allows bootstrap admin creation.
     */
    match /admins/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.token.email == "admin@epao.com" || isAdmin()) && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    /**
     * @description Authorized Public Attorney profiles.
     * Publicly readable so guests can see assigned lawyer names in the portal.
     */
    match /roleLawyer/{userId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /availability/{dateId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Citizen user profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || isLawyer();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /profile/{profileId} {
        allow read: if isOwner(userId) || isAdmin() || isLawyer();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Statutory standards for the Case Navigator. Publicly readable.
     */
    match /caseRequirements/{caseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Global appointments registry. 
     * Allows guest booking, management via reference code, and professional registry oversight.
     */
    match /appointments/{appointmentId} {
      // Explicitly allow read (get and list) for both public lookup and lawyer oversight
      allow read: if true; 
      allow create: if true;
      allow update: if true; 
      allow delete: if isAdmin();
    }

    /**
     * @description Official Legal Case records.
     */
    match /cases/{caseId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isLawyer();
      allow update: if isAdmin() || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      allow delete: if isAdmin();

      match /documents/{docId} {
        allow read, write: if isSignedIn(); 
      }
    }

    /**
     * @description Lawyer authorization lookup.
     */
    match /lawyersEmail/{email} {
      allow read: if true;
    }
  }
}