
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isLawyer() {
      return exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid));
    }

    function isClient() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // ===== APPOINTMENTS =====

    match /appointments/{apptId} {
      // Split List Rules for Query Guarantee
      
      // Admin: Full system oversight
      allow list: if isAdmin();
      
      // Staff (Lawyer): Access their assigned consultations
      allow list: if isSignedIn() && resource.data.lawyerId == request.auth.uid;
      
      // Registered Citizen (Client): Access their own booking history
      allow list: if isSignedIn() && resource.data.clientId == request.auth.uid;
      
      // Public Guest: Check availability (requires filtering by dateString)
      allow list: if resource.data.dateString != null;
      
      // Public Guest: Manage Booking (requires filtering by referenceCode)
      allow list: if resource.data.referenceCode != null;

      // GET logic for individual records
      allow get: if isAdmin() 
                 || (isSignedIn() && (resource.data.lawyerId == request.auth.uid || resource.data.clientId == request.auth.uid))
                 || resource.data.referenceCode != null;

      allow create: if true; // Unauthenticated booking allowed
      allow update: if isAdmin() 
                    || (isSignedIn() && (resource.data.lawyerId == request.auth.uid || resource.data.clientId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // ===== CASES =====

    match /cases/{caseId} {
      // Split List Rules for Query Guarantee
      allow list: if isAdmin();
      allow list: if isSignedIn() && resource.data.lawyerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.clientId == request.auth.uid;

      allow get: if isAdmin()
        || (isSignedIn() && (resource.data.lawyerId == request.auth.uid || resource.data.clientId == request.auth.uid));
      
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ===== USER REGISTRY =====

    match /users/{userId} {
      allow get: if isAdmin() || isLawyer() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if true; // Citizen registration
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /profile/{profileId} {
        allow read, write: if isAdmin() || isLawyer() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /admins/{adminId} {
      allow read, write: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
    }

    match /roleLawyer/{lawyerId} {
      allow list: if true; // Public list for system-wide assignment oversight
      allow get: if true; // Public profile view
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == lawyerId);
    }

    // ===== REFERENCE DATA =====

    match /caseRequirements/{reqId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
