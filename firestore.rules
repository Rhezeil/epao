
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roleAdmin/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "admin@epao.com")
      );
    }

    function isAuthorizedLawyer() {
      return isSignedIn() && (
        request.auth.uid == "ygkXuNUWJrbffovhXBtr6r1o5vr2" || 
        (request.auth.token.email != null && (
          request.auth.token.email.lower().split('@')[1] == 'lawyers.com' ||
          exists(/databases/$(database)/documents/lawyersEmail/$(request.auth.token.email.lower()))
        ))
      );
    }

    function isSystemAdmin() {
      return isSignedIn() && (
        request.auth.uid == "fs4k8QifPHSmUdshxh1NLweHSj73" || 
        (request.auth.token.email != null && request.auth.token.email.lower() == "admin@epao.com")
      );
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /users/{userId}/profile/{profileId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roleAdmin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /roleLawyer/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
      allow update: if isOwner(userId);
    }

    match /lawyersEmail/{emailId} {
      allow get: if true;
      allow list, write: if isAdmin();
    }

    match /caseRequirements/{caseName} {
      allow get: if true;
      allow list, write: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow get: if true; // Public access for reference code search
      allow create: if isSignedIn();
      allow update, delete, list: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
    }
  }
}
