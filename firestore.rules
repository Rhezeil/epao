
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.get('email', '');
    }

    function isAdmin() {
      return isSignedIn() && (
        getEmail() == "admin@epao.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isLawyer() {
      return isSignedIn() && (
        getEmail().matches(".*@lawyers.com$") || 
        getEmail().matches(".*@lawyers.mobile$") ||
        exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Centralized Notification Rules
    match /notifications/{docId} {
      // Allow create for guests so they can trigger system alerts (e.g. booking appointments)
      allow create: if true;
      allow read: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid == resource.data.get('targetUserId', '')
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid == resource.data.get('targetUserId', '')
      );
      allow delete: if false;
    }

    // Appointment Rules: Publicly queryable for status check via reference code
    match /appointments/{appointmentId} {
      allow read, list: if true; 
      allow create: if true;
      allow update: if true; 
      allow delete: if isAdmin();
    }

    match /lawyerDuties/{dutyId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.get('lawyerId', '') == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (getEmail() == "admin@epao.com" || isAdmin());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roleLawyer/{userId} {
      allow read, list: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow create, delete: if isAdmin();
      
      // Professional availability is public for scheduling transparency (red highlights/reasons)
      match /availability/{dateId} {
        allow read, list: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /users/{userId} {
      allow read, list: if true; 
      allow write: if isOwner(userId) || isAdmin() || isLawyer();

      match /{allSubcollections=**} {
        allow read, list: if true;
        allow write: if isOwner(userId) || isAdmin() || isLawyer();
      }
    }

    match /cases/{caseId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() || isLawyer();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.get('lawyerId', '') == request.auth.uid || isAdmin()));
      allow delete: if isAdmin();

      match /documents/{docId} {
        allow read, list, write: if isAdmin() || (isSignedIn() && (get(/databases/$(database)/documents/cases/$(caseId)).data.get('lawyerId', '') == request.auth.uid || get(/databases/$(database)/documents/cases/$(caseId)).data.get('clientId', '') == request.auth.uid));
      }
    }

    match /caseRequirements/{caseId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /lawyersEmail/{email} {
      allow read, list: if true;
    }
  }
}
