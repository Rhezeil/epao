
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LexConnect Security Architecture
     * Centralized synchronization for a multi-portal legal system.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "admin@epao.com") ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isLawyer() {
      return isSignedIn() && (
        (request.auth.token.email != null && (request.auth.token.email.lower().endsWith('@lawyers.com') || request.auth.token.email.lower().endsWith('@lawyers.mobile'))) ||
        exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- GLOBAL REGISTRIES ---

    match /appointments/{appointmentId} {
      // Allow read for everyone to support public booking verification and admin triage
      allow read: if true; 
      // Allow create for public portal and admin
      allow create: if true; 
      // Allow update for lawyers (status changes) and clients (rescheduling)
      allow update: if true; 
      // Only admins can purge visit records
      allow delete: if isAdmin();
    }

    match /lawyerDuties/{dutyId} {
      // All staff can see duty assignments
      allow read: if isSignedIn();
      // Only admins can allocate official duties
      allow create: if isAdmin();
      // Admins can update, and Lawyers can acknowledge their own duties
      allow update: if isAdmin() || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      // Only admins can delete assignments
      allow delete: if isAdmin();
    }

    // --- USER PROFILES & ROLES ---

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == "admin@epao.com");
    }

    match /roleLawyer/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /availability/{dateId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || isLawyer());
      allow write: if isOwner(userId) || isAdmin();

      match /profile/{profileId} {
        allow read: if isOwner(userId) || isAdmin() || isLawyer();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // --- CASE MANAGEMENT ---

    match /caseRequirements/{caseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cases/{caseId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.lawyerId == request.auth.uid || resource.data.clientId == request.auth.uid));
      allow list: if isAdmin() || isSignedIn();
      allow create: if isAdmin() || isLawyer();
      allow update: if isAdmin() || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
      allow delete: if isAdmin();

      match /documents/{docId} {
        allow read, write: if isAdmin() || (isSignedIn() && (get(/databases/$(database)/documents/cases/$(caseId)).data.lawyerId == request.auth.uid || get(/databases/$(database)/documents/cases/$(caseId)).data.clientId == request.auth.uid));
      }
    }

    match /lawyersEmail/{email} {
      allow read: if true;
    }
  }
}
