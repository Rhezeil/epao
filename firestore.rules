rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LEXCONNECT SECURITY RULES
     * Corrected to match actual collection names used in the app:
     * - roleAdmin, roleLawyer, users (clients), appointments, cases
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleAdmin/$(request.auth.uid));
    }

    function isLawyer() {
      return isSignedIn() && exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid));
    }

    function isClient() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /roleAdmin/{adminId} {
      allow read, write: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
    }

    match /roleLawyer/{lawyerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == lawyerId);
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();

      match /profile/{profileId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /appointments/{apptId} {
      allow read: if isAdmin() || isLawyer() || (isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.guestMobile != null));
      allow list: if isAdmin() || isLawyer();
      allow create: if true; // Public booking
      allow update: if isAdmin() || isLawyer() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /cases/{caseId} {
      allow read, list: if isAdmin() || (isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.lawyerId == request.auth.uid));
      allow create: if isAdmin();
      allow update: if isAdmin() || (isLawyer() && resource.data.lawyerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /caseRequirements/{reqId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /lawyersEmail/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}