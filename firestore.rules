
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isLawyer() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roleLawyer/$(request.auth.uid)) ||
        request.auth.token.email.lower().endsWith("@lawyers.com")
      );
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents and subcollections.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isLawyer();
      allow list: if isAdmin() || isLawyer();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /profile/{profileId} {
        allow get: if isOwner(userId) || isAdmin() || isLawyer();
        allow list: if isOwner(userId) || isAdmin() || isLawyer();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }

      match /availability/{availabilityId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Statutory Case Requirements & Procedures.
     * Publicly accessible for the Case Navigator.
     */
    match /caseRequirements/{reqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Rules for official Legal Cases and Documents.
     */
    match /cases/{caseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isLawyer() || isAdmin();
      allow delete: if isAdmin();

      match /documents/{docId} {
        allow get, list: if isSignedIn();
        allow create, update: if isLawyer() || isAdmin();
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Rules for Appointments.
     */
    match /appointments/{apptId} {
      allow get: if isSignedIn() || (request.query.filters.referenceCode != null);
      allow list: if isSignedIn() || (request.query.filters.dateString != null) || (request.query.filters.referenceCode != null);
      allow create: if true; 
      allow update: if isSignedIn() || (request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    /**
     * @description Role Marker Collections.
     */
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(adminId) && request.auth.token.email == "admin@epao.com";
      allow update, delete: if isAdmin();
    }

    match /roleLawyer/{lawyerId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(lawyerId) || isAdmin();
      allow update: if isOwner(lawyerId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /lawyersEmail/{email} {
      allow get: if true;
    }
  }
}
