
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a non-admin user (Client or Lawyer).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user (client or lawyer).",
          "enum": ["client", "lawyer"]
        },
        "profileId": {
          "type": "string",
          "description": "Reference to the user's profile."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "profileId"
      ]
    },
    "AccessControlRule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AccessControlRule",
      "type": "object",
      "description": "Represents an administrator's account and access rules.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The UID of the administrator."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin"]
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "permission": {
          "type": "string",
          "description": "Access level (e.g., 'read/write')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "role",
        "email"
      ]
    },
    "Profile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Profile",
      "type": "object",
      "description": "Personal details for a user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "phoneNumber": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      },
      "required": ["id", "firstName", "lastName"]
    },
    "LawyerAuthorization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LawyerAuthorization",
      "type": "object",
      "description": "Whitelist record for authorizing a lawyer email.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "authorizedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Client and Lawyer account records."
        }
      },
      {
        "path": "/users/{userId}/profile/profile",
        "definition": {
          "entityName": "Profile",
          "schema": {
            "$ref": "#/backend/entities/Profile"
          },
          "description": "User profile data."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "AccessControlRule",
          "schema": {
            "$ref": "#/backend/entities/AccessControlRule"
          },
          "description": "Admin-only account records."
        }
      },
      {
        "path": "/lawyersEmail/{emailId}",
        "definition": {
          "entityName": "LawyerAuthorization",
          "schema": {
            "$ref": "#/backend/entities/LawyerAuthorization"
          },
          "description": "Authorized lawyer email whitelist."
        }
      }
    ]
  }
}
