
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Top-level user account metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "lawyer", "client"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CaseRequirement": {
      "title": "CaseRequirement",
      "description": "Statutory documentary requirements and roadmaps for legal cases.",
      "type": "object",
      "properties": {
        "caseName": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "steps": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled legal consultation or follow-up visit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "referenceCode": { "type": "string" },
        "clientId": { "type": "string" },
        "lawyerId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "status": { "type": "string" },
        "caseType": { "type": "string" }
      }
    },
    "LegalCase": {
      "title": "LegalCase",
      "description": "An official legal case record handled by a public attorney.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "lawyerId": { "type": "string" },
        "caseType": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CaseDocument": {
      "title": "CaseDocument",
      "description": "Metadata for a document stored in a case digital folder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "folder": { "type": "string", "enum": ["Evidence", "Pleadings", "Court Orders", "Correspondence"] },
        "uploadDate": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" }
      }
    },
    "LawyerDuty": {
      "title": "LawyerDuty",
      "description": "An administrative assignment for a lawyer (Court, Field, Prison, etc).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lawyerId": { "type": "string" },
        "adminId": { "type": "string" },
        "category": { "type": "string", "enum": ["Office Work", "Field Work", "Court Work", "Prison and Jail Visits"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "notified": { "type": "boolean" }
      }
    },
    "SystemNotification": {
      "title": "SystemNotification",
      "description": "A system-wide event alert for administrative tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["appointment", "case", "lawyer", "client", "system"] },
        "userRole": { "type": "string", "enum": ["guest", "client", "lawyer", "admin"] },
        "description": { "type": "string" },
        "referenceId": { "type": "string" },
        "referenceCode": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "System administrator records."
    },
    "/roleLawyer/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Public attorney professional profiles."
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Citizen client accounts."
    },
    "/caseRequirements/{caseId}": {
      "schema": "#/backend/entities/CaseRequirement",
      "description": "Statutory database for public reference."
    },
    "/appointments/{appointmentId}": {
      "schema": "#/backend/entities/Appointment",
      "description": "Global appointment registry."
    },
    "/cases/{caseId}": {
      "schema": "#/backend/entities/LegalCase",
      "description": "Official active legal records."
    },
    "/cases/{caseId}/documents/{docId}": {
      "schema": "#/backend/entities/CaseDocument",
      "description": "Document metadata for case folders."
    },
    "/lawyerDuties/{dutyId}": {
      "schema": "#/backend/entities/LawyerDuty",
      "description": "Official administrative assignments registry."
    },
    "/notifications/{notificationId}": {
      "schema": "#/backend/entities/SystemNotification",
      "description": "Centralized system audit and activity notifications."
    }
  }
}
