
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the system (Admin, Client, or Lawyer).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user (admin, client, or lawyer)."
        },
        "profileId": {
          "type": "string",
          "description": "Reference to the user's profile. (Relationship: User 1:1 Profile)"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "profileId"
      ]
    },
    "Profile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Profile",
      "type": "object",
      "description": "Represents a user profile, containing personal information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Profile entity."
        },
        "firstName": {
          "type": "string",
          "description": "User's first name."
        },
        "lastName": {
          "type": "string",
          "description": "User's last name."
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's phone number."
        },
        "address": {
          "type": "string",
          "description": "User's address."
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName"
      ]
    },
    "AccessControlRule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AccessControlRule",
      "type": "object",
      "description": "Represents an access control rule for a specific role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AccessControlRule entity."
        },
        "role": {
          "type": "string",
          "description": "The role this rule applies to (admin, client, or lawyer)."
        },
        "resource": {
          "type": "string",
          "description": "The resource to which this rule applies (e.g., a specific UI element or data endpoint)."
        },
        "permission": {
          "type": "string",
          "description": "The permission granted by this rule (e.g., 'read', 'write', 'execute')."
        }
      },
      "required": [
        "id",
        "role",
        "resource",
        "permission"
      ]
    },
    "LawyerAuthorization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LawyerAuthorization",
      "type": "object",
      "description": "Represents an authorized email for a lawyer.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "authorizedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user authentication information.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier for the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/profile",
        "definition": {
          "entityName": "Profile",
          "schema": {
            "$ref": "#/backend/entities/Profile"
          },
          "description": "Stores user profile information.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier for the user."
            }
          ]
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "AccessControlRule",
          "schema": {
            "$ref": "#/backend/entities/AccessControlRule"
          },
          "description": "Admin role membership.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier for the admin user."
            }
          ]
        }
      },
      {
        "path": "/lawyersEmail/{emailId}",
        "definition": {
          "entityName": "LawyerAuthorization",
          "schema": {
            "$ref": "#/backend/entities/LawyerAuthorization"
          },
          "description": "Whitelist of authorized lawyer emails.",
          "params": [
            {
              "name": "emailId",
              "description": "Hashed or slugified email address."
            }
          ]
        }
      }
    ]
  }
}
