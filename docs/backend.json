
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a Client record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "admin", "lawyer"] },
        "profileId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role"]
    },
    "Case": {
      "title": "Case",
      "description": "Represents an official legal case record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "lawyerId": { "type": "string" },
        "caseType": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Pending", "Closed", "For Compliance"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientId", "lawyerId", "status"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Consultation booking record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "guestName": { "type": "string" },
        "guestMobile": { "type": "string" },
        "referenceCode": { "type": "string" },
        "caseType": { "type": "string" },
        "purpose": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "scheduled", "completed", "cancelled"] },
        "type": { "type": "string", "enum": ["initial", "follow-up"] },
        "lawyerId": { "type": "string" }
      },
      "required": ["referenceCode", "caseType", "date", "status"]
    },
    "LawyerAvailability": {
      "title": "LawyerAvailability",
      "description": "Blocked time slots for lawyers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lawyerId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "reason": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Account records."
    },
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Official case records."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Consultation and follow-up bookings."
    },
    "/lawyerAvailability/{availId}": {
      "schema": "LawyerAvailability",
      "description": "Practitioner blocked dates."
    }
  }
}
