{
  "entities": {
    "User": {
      "title": "User",
      "description": "Top-level user account metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "lawyer", "client"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CaseRequirement": {
      "title": "CaseRequirement",
      "description": "Statutory documentary requirements and roadmaps for legal matters.",
      "type": "object",
      "properties": {
        "caseName": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "steps": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled legal consultation or follow-up.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "referenceCode": { "type": "string" },
        "clientId": { "type": "string" },
        "lawyerId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "status": { "type": "string" },
        "caseType": { "type": "string" }
      }
    },
    "LegalCase": {
      "title": "LegalCase",
      "description": "An official legal record handled by a public attorney.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "lawyerId": { "type": "string" },
        "caseType": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CaseDocument": {
      "title": "CaseDocument",
      "description": "Metadata for a document stored in a case folder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "folder": { "type": "string", "enum": ["Evidence", "Pleadings", "Court Orders", "Correspondence"] },
        "uploadDate": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "System administrator records."
    },
    "/roleLawyer/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Public attorney professional profiles."
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Citizen client accounts."
    },
    "/caseRequirements/{caseId}": {
      "schema": "#/backend/entities/CaseRequirement",
      "description": "Statutory database for public reference."
    },
    "/appointments/{appointmentId}": {
      "schema": "#/backend/entities/Appointment",
      "description": "Global appointment registry."
    },
    "/cases/{caseId}": {
      "schema": "#/backend/entities/LegalCase",
      "description": "Official active legal records."
    },
    "/cases/{caseId}/documents/{docId}": {
      "schema": "#/backend/entities/CaseDocument",
      "description": "Document metadata for case folders."
    }
  }
}