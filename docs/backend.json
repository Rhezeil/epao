
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores general information for all users of the LexConnect application, including their role and basic profile details.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "lawyer", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "CaseRequirement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CaseRequirement",
      "type": "object",
      "description": "Stores statutory requirements and procedural roadmap steps for specific types of legal cases.",
      "properties": {
        "caseName": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "steps": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "step": { "type": "number" },
              "title": { "type": "string" },
              "content": { "type": "string" }
            }
          } 
        }
      }
    },
    "CaseDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CaseDocument",
      "type": "object",
      "description": "Metadata for documents associated with an active legal case, organized by folder.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "folder": { "type": "string", "enum": ["Pleadings", "Evidence", "Court Orders", "Correspondence"] },
        "uploadDate": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Basic user account data."
        }
      },
      {
        "path": "/caseRequirements/{caseId}",
        "definition": {
          "entityName": "CaseRequirement",
          "schema": { "$ref": "#/backend/entities/CaseRequirement" },
          "description": "Statutory guidance for legal matters."
        }
      },
      {
        "path": "/cases/{caseId}/documents/{docId}",
        "definition": {
          "entityName": "CaseDocument",
          "schema": { "$ref": "#/backend/entities/CaseDocument" },
          "description": "Folder-based document records for an active case."
        }
      }
    ]
  }
}
