{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a fundamental user account in the LexConnect system, storing common information and defining the user's role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used as a unique identifier for authentication.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The assigned role of the user (Admin, Client, or Lawyer)."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "AdminProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminProfile",
      "type": "object",
      "description": "Stores specific profile details for administrators.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UID)."
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "default": "admin"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "email",
        "role"
      ]
    },
    "ClientProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ClientProfile",
      "type": "object",
      "description": "Stores detailed personal and case-related information for registered citizens.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UID)."
        },
        "fullName": {
          "type": "string",
          "description": "The citizen's full legal name."
        },
        "mobileNumber": {
          "type": "string",
          "description": "Primary contact number."
        },
        "email": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "description": "Current system status (e.g., 'Active Case', 'New Intake', 'Closed Case')."
        },
        "incomeClassification": {
          "type": "string",
          "enum": ["Indigent", "Low Income", "Not Qualified"]
        }
      },
      "required": [
        "id",
        "fullName",
        "mobileNumber"
      ]
    },
    "LawyerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LawyerProfile",
      "type": "object",
      "description": "Stores professional information for PAO attorneys.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "photoUrl": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["Available", "Onsite", "On Leave"]
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled visit or intake request.",
      "properties": {
        "id": { "type": "string" },
        "referenceCode": { "type": "string" },
        "clientId": { "type": "string" },
        "lawyerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "scheduled", "completed", "cancelled", "rescheduled"] },
        "dateString": { "type": "string" },
        "time": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "AdminProfile",
          "description": "Administrators with system-wide oversight."
        }
      },
      {
        "path": "/roleLawyer/{lawyerId}",
        "definition": {
          "entityName": "LawyerProfile",
          "description": "Authorized public attorneys."
        }
      },
      {
        "path": "/users/{clientId}",
        "definition": {
          "entityName": "ClientProfile",
          "description": "Registered citizens and their case history."
        }
      },
      {
        "path": "/appointments/{apptId}",
        "definition": {
          "entityName": "Appointment",
          "description": "Client visit logs and requests."
        }
      }
    ]
  }
}